{
  "name": "silverbox",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Node-based, non-destructive RAW/JPEG development app with WGSL custom looks and git-native (JSON) graph documents.",
  "author": "takumifukasawa",
  "main": "./out/main/index.js",
  "bin": {
    "silverbox-render": "./bin/silverbox-render"
  },
  "build": {
    "appId": "dev.takumifukasawa.silverbox",
    "productName": "Silverbox",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "**/node_modules/sharp/**",
      "**/node_modules/@img/**",
      "**/node_modules/onnxruntime-node/**",
      "**/node_modules/onnxruntime-common/**"
    ],
    "mac": {
      "identity": null,
      "fileAssociations": [
        {
          "ext": "silverbox",
          "name": "Silverbox Project",
          "description": "Silverbox project manifest (docs/brief-bank/project-storage.md)",
          "role": "Editor"
        }
      ]
    }
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "package": "electron-vite build && electron-builder --dir",
    "render": "electron . --render",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "test:unit": "vitest run",
    "verify:ms0": "node scripts/verify-ms0-decode.mjs",
    "verify:ms1": "node scripts/verify-ms1-app.mjs",
    "verify:ms2": "node scripts/verify-ms2-decode-display.mjs",
    "verify:ms3": "node scripts/verify-ms3-webgpu.mjs",
    "verify:ms4": "node scripts/verify-ms4-graph.mjs",
    "verify:ms5": "node scripts/verify-ms5-edit.mjs",
    "verify:ms6": "node scripts/verify-ms6-persist.mjs",
    "verify:ms7": "node scripts/verify-ms7-custom.mjs",
    "verify:ms8": "node scripts/verify-ms8-export.mjs",
    "verify:ms9": "node scripts/verify-ms9-viewport.mjs",
    "verify:ms10": "node scripts/verify-ms10-histogram.mjs",
    "verify:ms11": "node scripts/verify-ms11-undo.mjs",
    "verify:ms12": "node scripts/verify-ms12-tonecurve.mjs",
    "verify:ms13": "node scripts/verify-ms13-branch.mjs",
    "verify:ms14": "node scripts/verify-ms14-package.mjs",
    "verify:develop": "node scripts/verify-develop.mjs",
    "verify:editing": "node scripts/verify-editing.mjs",
    "verify:wb": "node scripts/verify-wb.mjs",
    "verify:tonecurve": "node scripts/verify-tonecurve.mjs",
    "verify:hsl": "node scripts/verify-hsl.mjs",
    "verify:bw": "node scripts/verify-bw.mjs",
    "verify:sidecar-spec": "node scripts/verify-sidecar-spec.mjs",
    "verify:detail": "node scripts/verify-detail.mjs",
    "verify:dnd": "node scripts/verify-dnd.mjs",
    "verify:view": "node scripts/verify-view.mjs",
    "verify:grading": "node scripts/verify-grading.mjs",
    "verify:scopes": "node scripts/verify-scopes.mjs",
    "verify:effects": "node scripts/verify-effects.mjs",
    "verify:crop": "node scripts/verify-crop.mjs",
    "verify:lens": "node scripts/verify-lens.mjs",
    "verify:cst": "node scripts/verify-cst.mjs",
    "verify:polish": "node scripts/verify-polish.mjs",
    "verify:exportsettings": "node scripts/verify-exportsettings.mjs",
    "verify:masks": "node scripts/verify-masks.mjs",
    "verify:colorkey": "node scripts/verify-colorkey.mjs",
    "verify:spots": "node scripts/verify-spots.mjs",
    "verify:lut": "node scripts/verify-lut.mjs",
    "verify:presets": "node scripts/verify-presets.mjs",
    "verify:lensprofile": "node scripts/verify-lensprofile.mjs",
    "verify:basecurve": "node scripts/verify-basecurve.mjs",
    "verify:profilefit": "node scripts/verify-profilefit.mjs",
    "verify:hotreload": "node scripts/verify-hotreload.mjs",
    "verify:cli": "node scripts/verify-cli.mjs",
    "verify:cli-project": "node scripts/verify-cli-project.mjs",
    "verify:diff": "node scripts/verify-diff.mjs",
    "verify:golden": "node scripts/verify-golden.mjs",
    "verify:preview": "node scripts/verify-preview.mjs",
    "verify:filmstrip": "node scripts/verify-filmstrip.mjs",
    "verify:compare": "node scripts/verify-compare.mjs",
    "verify:nodepreview": "node scripts/verify-nodepreview.mjs",
    "verify:ratings": "node scripts/verify-ratings.mjs",
    "verify:flags": "node scripts/verify-flags.mjs",
    "verify:imagenode": "node scripts/verify-imagenode.mjs",
    "verify:external": "node scripts/verify-external.mjs",
    "verify:denoise": "node scripts/verify-denoise.mjs",
    "verify:bypass": "node scripts/verify-bypass.mjs",
    "verify:project": "node scripts/verify-project.mjs",
    "verify:project2": "node scripts/verify-project2.mjs",
    "verify:undo": "node scripts/verify-undo.mjs",
    "verify:sync": "node scripts/verify-sync.mjs",
    "fit:basecurve": "node scripts/fit-base-curve.mjs",
    "fit:profile": "node scripts/fit-profile.mjs",
    "verify": "node scripts/run-verify.mjs",
    "verify:smoke": "node scripts/run-verify.mjs --smoke",
    "verify:serial": "npm run verify:sidecar-spec && npm run verify:ms0 && npm run verify:ms1 && npm run verify:ms2 && npm run verify:ms3 && npm run verify:ms4 && npm run verify:ms5 && npm run verify:ms6 && npm run verify:ms7 && npm run verify:ms8 && npm run verify:ms9 && npm run verify:ms10 && npm run verify:ms11 && npm run verify:ms12 && npm run verify:ms13 && npm run verify:develop && npm run verify:editing && npm run verify:wb && npm run verify:tonecurve && npm run verify:hsl && npm run verify:bw && npm run verify:detail && npm run verify:dnd && npm run verify:view && npm run verify:grading && npm run verify:scopes && npm run verify:effects && npm run verify:crop && npm run verify:lens && npm run verify:cst && npm run verify:polish && npm run verify:exportsettings && npm run verify:masks && npm run verify:colorkey && npm run verify:spots && npm run verify:lut && npm run verify:presets && npm run verify:hotreload && npm run verify:cli && npm run verify:cli-project && npm run verify:diff && npm run verify:golden && npm run verify:preview && npm run verify:filmstrip && npm run verify:compare && npm run verify:nodepreview && npm run verify:ratings && npm run verify:flags && npm run verify:imagenode && npm run verify:external && npm run verify:denoise && npm run verify:bypass && npm run verify:project && npm run verify:project2 && npm run verify:undo && npm run verify:sync && npm run verify:ms14",
    "perf:probe": "node scripts/perf-probe.mjs"
  },
  "devDependencies": {
    "@types/dagre": "^0.7.54",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "@webgpu/types": "^0.1.71",
    "@xyflow/react": "^12.11.2",
    "dagre": "^0.8.5",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "esbuild": "^0.28.1",
    "monaco-editor": "^0.55.1",
    "playwright": "^1.61.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^6.0.3",
    "vite": "^7.3.6",
    "vitest": "^3.2.7",
    "zustand": "^5.0.14"
  },
  "dependencies": {
    "libraw-wasm": "1.6.0",
    "onnxruntime-node": "^1.27.0",
    "sharp": "^0.35.3"
  }
}
